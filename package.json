{
  "name": "figma-ai-connect-mcp",
  "description": "MCP server + Figma plugin that let AI agents read and edit Figma over a local WebSocket. FigmaAIConnect adds image/font/effect/gradient/SVG commands and a batch_ops command that builds whole pages in one round-trip.",
  "version": "0.4.0",
  "license": "MIT",
  "author": "Prakhar Gupta",
  "homepage": "https://github.com/guptaprakhariitr/figma-ai-connect-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/guptaprakhariitr/figma-ai-connect-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/guptaprakhariitr/figma-ai-connect-mcp/issues"
  },
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "design",
    "automation",
    "websocket"
  ],
  "module": "dist/server.js",
  "main": "dist/server.js",
  "bin": {
    "figma-ai-connect-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "src/figma_plugin",
    "src/socket.ts",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "start": "bun run dist/server.js",
    "socket": "bun run src/socket.ts",
    "setup": "./scripts/setup.sh",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "bun run build:watch",
    "test": "bun tests/coverage.mjs",
    "test:smoke": "bun tests/smoke.mjs",
    "pub:release": "bun run build && npm publish"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.2.5",
    "tsup": "^8.4.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.13.1",
    "uuid": "latest",
    "ws": "latest",
    "zod": "3.22.4"
  }
}
